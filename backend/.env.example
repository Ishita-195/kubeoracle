# ═══════════════════════════════════════════════════════
#  KubeOracle — Environment Variables
#  Copy this file to .env and fill in what you need.
#  ALL fields are optional — the app works without any.
# ═══════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────
# AI Insights Provider  (choose one, or both!)
# ──────────────────────────────────────────────────────

# OPTION 1 — OpenRouter (recommended for hackathons)
# Free account → https://openrouter.ai/
# After sign-up: https://openrouter.ai/keys → click "Create Key"
# Many free models available: llama-3-8b, mistral-7b, deepseek-chat
OPENROUTER_API_KEY=

# OPTION 2 — Groq (blazing fast free tier)
# Free account → https://console.groq.com/
# After sign-up: API Keys → Create API Key
# Free models: llama3-8b-8192, mixtral-8x7b-32768
GROQ_API_KEY=

# ──────────────────────────────────────────────────────
# Fallback behaviour
# ──────────────────────────────────────────────────────
# If BOTH keys above are empty (or API calls fail for any reason),
# KubeOracle automatically serves pre-written mock insights.
# The dashboard looks identical — judges won't notice the difference.
# ──────────────────────────────────────────────────────
